<UserControl x:Class="Cattech.Optimizer.Pro.UI.Views.CompanySettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Cattech.Optimizer.Pro.UI.ViewModels"
             xmlns:converters="clr-namespace:Cattech.Optimizer.Pro.UI.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30">
        <StackPanel MaxWidth="700" HorizontalAlignment="Left">

            <!-- Título -->
            <TextBlock Text="Configuración de Empresa / Técnico"
                       FontSize="26" FontWeight="Bold"
                       Foreground="#1B1B1B" Margin="0,0,0,5" />
            <TextBlock Text="Estos datos se usarán en los informes HTML y PDF generados."
                       FontSize="13" Foreground="#666" Margin="0,0,0,25" />

            <!-- Mensajes de estado -->
            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,15"
                    Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVis}}"
                    Background="#E6F4EA" BorderBrush="#34A853" BorderThickness="1">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#1E7E34" FontWeight="SemiBold" />
            </Border>

            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,15"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                    Background="#FDECEA" BorderBrush="#D93025" BorderThickness="1">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#C62828" FontWeight="SemiBold" />
            </Border>

            <!-- Sección: Datos de la Empresa -->
            <TextBlock Text="DATOS DE LA EMPRESA" FontSize="12" FontWeight="Bold"
                       Foreground="#0078D4" Margin="0,0,0,12" />

            <!-- Nombre comercial -->
            <TextBlock Text="Nombre comercial *" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
            <TextBox Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}"
                     Padding="10,8" FontSize="14" Margin="0,0,0,15"
                     BorderBrush="#CCC" BorderThickness="1" />

            <!-- Técnico responsable -->
            <TextBlock Text="Técnico responsable *" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
            <TextBox Text="{Binding TechnicianName, UpdateSourceTrigger=PropertyChanged}"
                     Padding="10,8" FontSize="14" Margin="0,0,0,15"
                     BorderBrush="#CCC" BorderThickness="1" />

            <!-- CUIT/DNI -->
            <TextBlock Text="CUIT / DNI" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
            <TextBox Text="{Binding TaxId, UpdateSourceTrigger=PropertyChanged}"
                     Padding="10,8" FontSize="14" Margin="0,0,0,15"
                     BorderBrush="#CCC" BorderThickness="1" />

            <!-- Sección: Contacto -->
            <TextBlock Text="CONTACTO" FontSize="12" FontWeight="Bold"
                       Foreground="#0078D4" Margin="0,5,0,12" />

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="15" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Teléfono" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="14"
                             BorderBrush="#CCC" BorderThickness="1" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="WhatsApp" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
                    <TextBox Text="{Binding WhatsApp, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="14"
                             BorderBrush="#CCC" BorderThickness="1" />
                </StackPanel>
            </Grid>

            <!-- Email -->
            <TextBlock Text="Email" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                     Padding="10,8" FontSize="14" Margin="0,0,0,15"
                     BorderBrush="#CCC" BorderThickness="1" />

            <!-- Dirección y Ciudad -->
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="15" />
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Dirección" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
                    <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="14"
                             BorderBrush="#CCC" BorderThickness="1" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Ciudad" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
                    <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="14"
                             BorderBrush="#CCC" BorderThickness="1" />
                </StackPanel>
            </Grid>

            <!-- Sección: Marca -->
            <TextBlock Text="IDENTIDAD VISUAL" FontSize="12" FontWeight="Bold"
                       Foreground="#0078D4" Margin="0,5,0,12" />

            <!-- Logo -->
            <TextBlock Text="Logo de la empresa" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="1"
                        CornerRadius="4" Padding="10,6" MinHeight="42"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding LogoPath}"
                               VerticalAlignment="Center"
                               Foreground="{Binding LogoPath, Converter={StaticResource LogoPathColorConverter}}"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis" />
                </Border>

                <Button Grid.Column="2" Content="Seleccionar logo"
                        Command="{Binding BrowseLogoCommand}"
                        Padding="16,8" FontSize="13" FontWeight="SemiBold"
                        Background="#F3F3F3" Foreground="#333"
                        BorderBrush="#CCC" BorderThickness="1"
                        Cursor="Hand" />
            </Grid>

            <!-- Vista previa del logo -->
            <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="6"
                    Padding="15" Margin="0,0,0,15" Background="#FAFAFA"
                    Visibility="{Binding HasLogo, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Vista previa del logo:" FontSize="12" Foreground="#666" Margin="0,0,0,8" />
                    <Image MaxHeight="100" MaxWidth="300"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Source" Value="{Binding LogoPath}" />
                            </Style>
                        </Image.Style>
                    </Image>
                </StackPanel>
            </Border>

            <!-- Color principal -->
            <TextBlock Text="Color principal (hex)" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="4" BorderBrush="#CCC" BorderThickness="1"
                        Padding="0" ClipToBounds="True" Height="36" VerticalAlignment="Center">
                    <Border.Background>
                        <SolidColorBrush Color="{Binding PrimaryColor, Converter={StaticResource HexToColorConverter}}" />
                    </Border.Background>
                </Border>

                <TextBox Grid.Column="2"
                         Text="{Binding PrimaryColor, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10,8" FontSize="14"
                         BorderBrush="#CCC" BorderThickness="1" />
            </Grid>

            <!-- Leyenda del pie -->
            <TextBlock Text="Leyenda del pie de informe" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
            <TextBox Text="{Binding FooterLegend, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap" Height="70"
                     Padding="10,8" FontSize="13" Margin="0,0,0,25"
                     BorderBrush="#CCC" BorderThickness="1"
                     VerticalScrollBarVisibility="Auto" />

            <!-- Botones de acción -->
            <Separator Background="#E0E0E0" Margin="0,0,0,15" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,30">
                <Button Content="Cancelar"
                        Command="{Binding CancelCommand}"
                        Padding="20,10" FontSize="13" Margin="0,0,10,0"
                        Background="#F3F3F3" Foreground="#555"
                        BorderBrush="#CCC" BorderThickness="1"
                        Cursor="Hand" />

                <Button Content="Guardar configuración"
                        Command="{Binding SaveCommand}"
                        Padding="20,10" FontSize="13" FontWeight="SemiBold"
                        Background="#0078D4" Foreground="White"
                        BorderThickness="0" Cursor="Hand" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
