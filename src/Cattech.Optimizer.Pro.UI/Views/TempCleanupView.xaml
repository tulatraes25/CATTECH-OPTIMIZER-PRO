<UserControl x:Class="Cattech.Optimizer.Pro.UI.Views.TempCleanupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Cattech.Optimizer.Pro.UI.Converters"
             xmlns:cleanup="clr-namespace:Cattech.Optimizer.Pro.Core.Models.Cleanup;assembly=Cattech.Optimizer.Pro.Core">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InvertBoolConverter x:Key="InvertBool" />
        <converters:ZeroToVisibilityConverter x:Key="ZeroToVis" />
        <converters:StringToVisibilityConverter x:Key="StringToVis" />
        <converters:RiskColorConverter x:Key="RiskColorConverter" />

        <Style x:Key="ColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F0F0F0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="10,8" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Título -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Limpieza Segura de Temporales" FontSize="26" FontWeight="Bold" Foreground="#1B1B1B" />
            <TextBlock Text="Escaneá y limpiá archivos temporales seguros. No se tocan datos personales ni carpetas sensibles." FontSize="13" Foreground="#666" Margin="0,5,0,0" />
        </StackPanel>

        <!-- Row 1: Mensajes -->
        <StackPanel Grid.Row="1">
            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,10"
                    Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVis}}"
                    Background="#E6F4EA" BorderBrush="#34A853" BorderThickness="1">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#1E7E34" FontWeight="SemiBold" />
            </Border>
            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,10"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                    Background="#FDECEA" BorderBrush="#D93025" BorderThickness="1">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#C62828" FontWeight="SemiBold" />
            </Border>
        </StackPanel>

        <!-- Row 2: Botones principales -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="🔍 Escanear temporales"
                    Command="{Binding ScanCommand}" Padding="16,8" FontSize="12" FontWeight="SemiBold"
                    Background="#0078D4" Foreground="White" BorderThickness="0"
                    IsEnabled="{Binding IsRunning, Converter={StaticResource InvertBool}}" />

            <Button Grid.Column="2" Content="🧹 Limpiar seleccionados"
                    Command="{Binding CleanupCommand}" Padding="16,8" FontSize="12" FontWeight="SemiBold"
                    Background="#E53935" Foreground="White" BorderThickness="0"
                    IsEnabled="{Binding HasScanned, Converter={StaticResource BoolToVis}}" />

            <Button Grid.Column="4" Content="Seleccionar bajos riesgo"
                    Command="{Binding SelectAllLowRiskCommand}" Padding="12,8" FontSize="11"
                    Background="#F3F3F3" Foreground="#333" BorderBrush="#CCC" BorderThickness="1" />

            <Button Grid.Column="6" Content="Limpiar selección"
                    Command="{Binding DeselectAllCommand}" Padding="12,8" FontSize="11"
                    Background="#F3F3F3" Foreground="#333" BorderBrush="#CCC" BorderThickness="1" />

            <StackPanel Grid.Column="8" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding SelectedTargetsCount}" FontSize="14" FontWeight="Bold" Foreground="#333" Margin="0,0,5,0" />
                <TextBlock Text="seleccionados" FontSize="12" Foreground="#666" Margin="0,0,15,0" />
                <TextBlock Text="{Binding TotalSelectedSize}" FontSize="14" FontWeight="Bold" Foreground="#E65100" />
            </StackPanel>
        </Grid>

        <!-- Row 3: Barra de progreso -->
        <ProgressBar Grid.Row="3" Value="{Binding ProgressPercent}" Maximum="100"
                     Height="6" Margin="0,0,0,10"
                     Background="#E0E0E0" Foreground="#0078D4"
                     Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}" />

        <!-- Row 4: Contenido principal -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- Panel izquierdo: Lista de targets -->
            <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6"
                    Padding="15" Margin="0,0,10,0" Background="White">
                <StackPanel>
                    <TextBlock Text="UBICACIONES DETECTADAS" FontSize="12" FontWeight="Bold"
                               Foreground="#0078D4" Margin="0,0,0,10" />

                    <TextBlock Text="Ejecutá un escaneo primero" FontSize="12" Foreground="#999"
                               Visibility="{Binding HasScanned, Converter={StaticResource InvertBool}}" />

                    <ItemsControl ItemsSource="{Binding Targets}" MaxHeight="500">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type cleanup:TempCleanupTarget}">
                                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6"
                                        Padding="12,10" Margin="0,0,0,8" Background="White">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsAccessible}" VerticalAlignment="Top" Margin="0,2,10,0"
                                                  Command="{Binding DataContext.ToggleTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}" />

                                        <StackPanel Grid.Column="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" />
                                                <Border Grid.Column="1" CornerRadius="3" Padding="6,2"
                                                        Background="{Binding RiskLevel, Converter={StaticResource RiskColorConverter}}">
                                                    <TextBlock Text="{Binding RiskLevel}" FontSize="10" Foreground="White" />
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#666"
                                                       TextWrapping="Wrap" Margin="0,4,0,0" />
                                            <Grid Margin="0,6,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="15" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="15" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontSize="11">
                                                    <Run Text="{Binding EstimatedFileCount, Mode=OneWay}" FontWeight="SemiBold" />
                                                    <Run Text=" archivos" Foreground="#888" />
                                                </TextBlock>
                                                <TextBlock Grid.Column="2" FontSize="11">
                                                    <Run Text="{Binding EstimatedSizeMB, Mode=OneWay}" FontWeight="SemiBold" />
                                                    <Run Text=" MB" Foreground="#888" />
                                                </TextBlock>
                                                <TextBlock Grid.Column="4" FontSize="10" Foreground="#999"
                                                           Visibility="{Binding ScanNotes, Converter={StaticResource StringToVis}}">
                                                    <Run Text="{Binding ScanNotes, Mode=OneWay}" FontStyle="Italic" />
                                                </TextBlock>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Panel derecho: Resultado -->
            <Border Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6"
                    Padding="15" Background="#FAFAFA">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="RESULTADO" FontSize="12" FontWeight="Bold"
                                   Foreground="#0078D4" Margin="0,0,0,10" />

                        <TextBlock Text="{Binding ResultSummary}" FontSize="13" FontWeight="SemiBold"
                                   TextWrapping="Wrap" Margin="0,0,0,8"
                                   Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}" />

                        <TextBlock Text="{Binding ResultDetails}" FontSize="11" Foreground="#666"
                                   Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}" />

                        <StackPanel Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}" Margin="0,10,0,0">
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Archivos eliminados:" FontSize="11" Foreground="#555" />
                                <TextBlock Text="{Binding ResultDeletedFiles}" FontSize="11" FontWeight="SemiBold" Foreground="#2E7D32" Grid.Column="1" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Espacio liberado:" FontSize="11" Foreground="#555" />
                                <TextBlock Text="{Binding ResultDeletedSize}" FontSize="11" FontWeight="SemiBold" Foreground="#2E7D32" Grid.Column="1" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Omitidos:" FontSize="11" Foreground="#555" />
                                <TextBlock Text="{Binding ResultSkippedFiles}" FontSize="11" FontWeight="SemiBold" Foreground="#E65100" Grid.Column="1" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Con error:" FontSize="11" Foreground="#555" />
                                <TextBlock Text="{Binding ResultFailedFiles}" FontSize="11" FontWeight="SemiBold" Foreground="#C62828" Grid.Column="1" />
                            </Grid>
                        </StackPanel>

                        <!-- Errores -->
                        <StackPanel Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}" Margin="0,15,0,0">
                            <TextBlock Text="ERRORES" FontSize="11" FontWeight="Bold"
                                       Foreground="#C62828" Margin="0,0,0,6"
                                       Visibility="{Binding ResultErrors.Count, Converter={StaticResource ZeroToVis}}" />

                            <ItemsControl ItemsSource="{Binding ResultErrors}" MaxHeight="150">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type cleanup:CleanupError}">
                                        <Border Background="#FDECEA" CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                                            <StackPanel>
                                                <TextBlock Text="{Binding FilePath}" FontSize="10" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Message}" FontSize="10" Foreground="#666" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Advertencias de seguridad -->
                        <Border Background="#FFF8E1" CornerRadius="6" Padding="10" Margin="0,15,0,0"
                                Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="⚠️ Notas de seguridad" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#E65100" Margin="0,0,0,4" />
                                <TextBlock Text="• No se eliminan archivos bloqueados o en uso" FontSize="10" Foreground="#666" />
                                <TextBlock Text="• No se tocan Descargas, Documentos ni Escritorio" FontSize="10" Foreground="#666" />
                                <TextBlock Text="• No se eliminan perfiles de navegador" FontSize="10" Foreground="#666" />
                                <TextBlock Text="• Se omite Papelera si no fue seleccionada" FontSize="10" Foreground="#666" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
