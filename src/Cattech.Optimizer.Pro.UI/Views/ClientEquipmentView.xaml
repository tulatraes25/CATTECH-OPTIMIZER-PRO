<UserControl x:Class="Cattech.Optimizer.Pro.UI.Views.ClientEquipmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Cattech.Optimizer.Pro.UI.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30">
        <StackPanel MaxWidth="750" HorizontalAlignment="Left">

            <!-- Título -->
            <TextBlock Text="Cliente y Equipo"
                       FontSize="26" FontWeight="Bold"
                       Foreground="#1B1B1B" Margin="0,0,0,5" />
            <TextBlock Text="Completá los datos del cliente y del equipo. Usá 'Detectar datos del equipo' para auto-completar."
                       FontSize="13" Foreground="#666" Margin="0,0,0,25" />

            <!-- Mensajes de estado -->
            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,15"
                    Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVis}}"
                    Background="#E6F4EA" BorderBrush="#34A853" BorderThickness="1">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#1E7E34" FontWeight="SemiBold" />
            </Border>

            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,15"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                    Background="#FDECEA" BorderBrush="#D93025" BorderThickness="1">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#C62828" FontWeight="SemiBold" />
            </Border>

            <!-- Sección: Datos del Cliente -->
            <TextBlock Text="DATOS DEL CLIENTE" FontSize="12" FontWeight="Bold"
                       Foreground="#0078D4" Margin="0,0,0,12" />

            <!-- Nombre y Empresa -->
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="15" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Nombre *" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
                    <TextBox Text="{Binding ClientName, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="14" BorderBrush="#CCC" BorderThickness="1" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Empresa / Organización" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
                    <TextBox Text="{Binding ClientCompany, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="14" BorderBrush="#CCC" BorderThickness="1" />
                </StackPanel>
            </Grid>

            <!-- Teléfono y Email -->
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="15" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Teléfono" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
                    <TextBox Text="{Binding ClientPhone, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="14" BorderBrush="#CCC" BorderThickness="1" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Email" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
                    <TextBox Text="{Binding ClientEmail, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="14" BorderBrush="#CCC" BorderThickness="1" />
                </StackPanel>
            </Grid>

            <!-- Dirección -->
            <TextBlock Text="Dirección" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
            <TextBox Text="{Binding ClientAddress, UpdateSourceTrigger=PropertyChanged}"
                     Padding="10,8" FontSize="14" Margin="0,0,0,15"
                     BorderBrush="#CCC" BorderThickness="1" />

            <!-- Observaciones del cliente -->
            <TextBlock Text="Observaciones del cliente" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
            <TextBox Text="{Binding ClientNotes, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap" Height="55"
                     Padding="10,8" FontSize="13" Margin="0,0,0,20"
                     BorderBrush="#CCC" BorderThickness="1"
                     VerticalScrollBarVisibility="Auto" />

            <Separator Background="#E0E0E0" Margin="0,0,0,20" />

            <!-- Sección: Datos del Equipo -->
            <TextBlock Text="DATOS DEL EQUIPO" FontSize="12" FontWeight="Bold"
                       Foreground="#0078D4" Margin="0,0,0,12" />

            <!-- Marca, Modelo, Tipo -->
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="150" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Marca" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
                    <TextBox Text="{Binding EquipmentBrand, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="14" BorderBrush="#CCC" BorderThickness="1" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Modelo" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
                    <TextBox Text="{Binding EquipmentModel, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="14" BorderBrush="#CCC" BorderThickness="1" />
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Tipo *" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding EquipmentTypes}"
                              SelectedItem="{Binding EquipmentType}"
                              Padding="10,8" FontSize="14"
                              BorderBrush="#CCC" BorderThickness="1" />
                </StackPanel>
            </Grid>

            <!-- Número de serie -->
            <TextBlock Text="Número de serie" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
            <TextBox Text="{Binding SerialNumber, UpdateSourceTrigger=PropertyChanged}"
                     Padding="10,8" FontSize="14" Margin="0,0,0,15"
                     BorderBrush="#CCC" BorderThickness="1" />

            <!-- Motivo del servicio -->
            <TextBlock Text="Motivo del servicio *" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
            <TextBox Text="{Binding ServiceReason, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap" Height="60"
                     Padding="10,8" FontSize="13" Margin="0,0,0,15"
                     BorderBrush="#CCC" BorderThickness="1"
                     VerticalScrollBarVisibility="Auto" />

            <!-- Observaciones del equipo -->
            <TextBlock Text="Observaciones del equipo" FontSize="13" Foreground="#333" Margin="0,0,0,4" />
            <TextBox Text="{Binding EquipmentNotes, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap" Height="55"
                     Padding="10,8" FontSize="13" Margin="0,0,0,20"
                     BorderBrush="#CCC" BorderThickness="1"
                     VerticalScrollBarVisibility="Auto" />

            <Separator Background="#E0E0E0" Margin="0,0,0,20" />

            <!-- Sección: Datos detectados -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="DATOS DETECTADOS AUTOMÁTICAMENTE"
                           FontSize="12" FontWeight="Bold" Foreground="#0078D4"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="{Binding DetectionStatus}" FontSize="11"
                               Foreground="#666" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <Button Content="🔍 Detectar datos del equipo"
                            Command="{Binding DetectHardwareCommand}"
                            Padding="14,8" FontSize="12" FontWeight="SemiBold"
                            Background="#F3F3F3" Foreground="#333"
                            BorderBrush="#CCC" BorderThickness="1"
                            Cursor="Hand"
                            IsEnabled="{Binding IsDetecting, Converter={StaticResource InvertBoolConverter}}" />
                </StackPanel>
            </Grid>

            <!-- Grid de datos detectados -->
            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="6"
                    Padding="15" Margin="0,0,0,25" Background="#FAFAFA"
                    Visibility="{Binding HasDetectedData, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Row 0: SO + Edición -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Sistema operativo:"
                               FontSize="12" FontWeight="SemiBold" Foreground="#555" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DetectedOS}"
                               FontSize="12" Foreground="#333" />
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Edición:"
                               FontSize="12" FontWeight="SemiBold" Foreground="#555" />
                    <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding DetectedEdition}"
                               FontSize="12" Foreground="#333" />

                    <!-- Row 2: Arquitectura + Usuario -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Arquitectura:"
                               FontSize="12" FontWeight="SemiBold" Foreground="#555" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DetectedArchitecture}"
                               FontSize="12" Foreground="#333" />
                    <TextBlock Grid.Row="2" Grid.Column="3" Text="Usuario:"
                               FontSize="12" FontWeight="SemiBold" Foreground="#555" />
                    <TextBlock Grid.Row="2" Grid.Column="4" Text="{Binding DetectedUser}"
                               FontSize="12" Foreground="#333" />

                    <!-- Row 4: CPU + RAM -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Procesador:"
                               FontSize="12" FontWeight="SemiBold" Foreground="#555" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DetectedProcessor}"
                               FontSize="12" Foreground="#333" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Row="4" Grid.Column="3" Text="RAM:"
                               FontSize="12" FontWeight="SemiBold" Foreground="#555" />
                    <TextBlock Grid.Row="4" Grid.Column="4" Text="{Binding DetectedRam}"
                               FontSize="12" Foreground="#333" />

                    <!-- Row 6: Disco + Capacidad -->
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Disco principal:"
                               FontSize="12" FontWeight="SemiBold" Foreground="#555" />
                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding DetectedDisk}"
                               FontSize="12" Foreground="#333" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Row="6" Grid.Column="3" Text="Capacidad:"
                               FontSize="12" FontWeight="SemiBold" Foreground="#555" />
                    <TextBlock Grid.Row="6" Grid.Column="4"
                               FontSize="12" Foreground="#333">
                        <Run Text="{Binding DetectedDiskCapacity, Mode=OneWay}" />
                        <Run Text=" | Libre: " Foreground="#888" />
                        <Run Text="{Binding DetectedDiskFree, Mode=OneWay}" />
                    </TextBlock>

                    <!-- Row 8: Tipo disco + Nombre equipo -->
                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Tipo de disco:"
                               FontSize="12" FontWeight="SemiBold" Foreground="#555" />
                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding DetectedDiskType}"
                               FontSize="12" Foreground="#333" />
                    <TextBlock Grid.Row="8" Grid.Column="3" Text="Equipo:"
                               FontSize="12" FontWeight="SemiBold" Foreground="#555" />
                    <TextBlock Grid.Row="8" Grid.Column="4" Text="{Binding DetectedComputerName}"
                               FontSize="12" Foreground="#333" />
                </Grid>
            </Border>

            <!-- Botones de acción -->
            <Separator Background="#E0E0E0" Margin="0,0,0,15" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,30">
                <Button Content="Nuevo registro"
                        Command="{Binding NewRecordCommand}"
                        Padding="16,10" FontSize="13" Margin="0,0,10,0"
                        Background="#FFF3E0" Foreground="#E65100"
                        BorderBrush="#FFCC80" BorderThickness="1"
                        Cursor="Hand" />

                <Button Content="Cancelar"
                        Command="{Binding CancelCommand}"
                        Padding="20,10" FontSize="13" Margin="0,0,10,0"
                        Background="#F3F3F3" Foreground="#555"
                        BorderBrush="#CCC" BorderThickness="1"
                        Cursor="Hand" />

                <Button Content="Guardar cliente/equipo"
                        Command="{Binding SaveCommand}"
                        Padding="20,10" FontSize="13" FontWeight="SemiBold"
                        Background="#0078D4" Foreground="White"
                        BorderThickness="0" Cursor="Hand" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
