<UserControl x:Class="Cattech.Optimizer.Pro.UI.Views.StartupAnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Cattech.Optimizer.Pro.UI.Converters"
             xmlns:vm="clr-namespace:Cattech.Optimizer.Pro.UI.ViewModels"
             xmlns:startup="clr-namespace:Cattech.Optimizer.Pro.Core.Models.Startup;assembly=Cattech.Optimizer.Pro.Core">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InvertBoolConverter x:Key="InvertBool" />
        <converters:StringToVisibilityConverter x:Key="StringToVis" />
        <converters:ZeroToVisibilityConverter x:Key="ZeroToVis" />
        <converters:RestoreColorConverter x:Key="RestoreColorConverter" />
        <converters:RestoreTextConverter x:Key="RestoreTextConverter" />

        <Style x:Key="ColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F0F0F0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Título -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Programas de Inicio" FontSize="26" FontWeight="Bold" Foreground="#1B1B1B" />
            <TextBlock Text="Análisis, desactivación segura y reversión de programas de inicio." FontSize="13" Foreground="#666" Margin="0,5,0,0" />
        </StackPanel>

        <!-- Row 1: Mensajes -->
        <StackPanel Grid.Row="1">
            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,10"
                    Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVis}}"
                    Background="#E6F4EA" BorderBrush="#34A853" BorderThickness="1">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#1E7E34" FontWeight="SemiBold" />
            </Border>
            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,10"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                    Background="#FDECEA" BorderBrush="#D93025" BorderThickness="1">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#C62828" FontWeight="SemiBold" />
            </Border>
        </StackPanel>

        <!-- Row 2: Botones principales -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="🔍 Analizar"
                    Command="{Binding AnalyzeCommand}" Padding="16,8" FontSize="12"
                    Background="#0078D4" Foreground="White" BorderThickness="0"
                    IsEnabled="{Binding IsRunning, Converter={StaticResource InvertBool}}" />

            <Button Grid.Column="2" Content="💾 Guardar"
                    Command="{Binding SaveAnalysisCommand}" Padding="16,8" FontSize="12"
                    Background="#F3F3F3" Foreground="#333" BorderBrush="#CCC" BorderThickness="1"
                    IsEnabled="{Binding HasResults}" />

            <Button Grid.Column="4" Content="📋 Backups"
                    Command="{Binding LoadBackupsCommand}" Padding="16,8" FontSize="12"
                    Background="#F3F3F3" Foreground="#333" BorderBrush="#CCC" BorderThickness="1" />

            <TextBlock Grid.Column="6" Text="{Binding StatusText}" FontSize="12" Foreground="#666" VerticalAlignment="Center" />
        </Grid>

        <!-- Row 3: Barra de desactivación -->
        <Border Grid.Row="3" BorderBrush="#FFB74D" BorderThickness="1" CornerRadius="6"
                Padding="12,10" Margin="0,0,0,10" Background="#FFF8E1"
                Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="⚡ Desactivar:" FontSize="12" FontWeight="SemiBold"
                           Foreground="#E65100" VerticalAlignment="Center" />

                <TextBlock Grid.Column="1" FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="10,0">
                    <Run Text="{Binding SelectedCount, Mode=OneWay}" FontWeight="Bold" />
                    <Run Text=" seleccionadas" />
                </TextBlock>

                <Button Grid.Column="2" Content="Seleccionar posibles desactivar"
                        Command="{Binding SelectAllPossibleDisableCommand}" Padding="10,6" FontSize="11"
                        Background="#FFF3E0" Foreground="#E65100" BorderBrush="#FFCC80" BorderThickness="1" />

                <Button Grid.Column="3" Content="Limpiar selección"
                        Command="{Binding ClearSelectionCommand}" Padding="10,6" FontSize="11"
                        Background="#F5F5F5" Foreground="#666" BorderBrush="#DDD" BorderThickness="1" Margin="5,0" />

                <TextBox Grid.Column="4" Text="{Binding DisableReason, UpdateSourceTrigger=PropertyChanged}"
                         Width="150" Padding="8,6" FontSize="11" Margin="5,0"
                         BorderBrush="#CCC" BorderThickness="1" VerticalContentAlignment="Center"
                         ToolTip="Motivo de la desactivación (opcional)" />

                <Button Grid.Column="5" Content="🚫 Desactivar seleccionados"
                        Command="{Binding DisableSelectedCommand}" Padding="14,6" FontSize="12" FontWeight="SemiBold"
                        Background="#E53935" Foreground="White" BorderThickness="0" Margin="5,0"
                        IsEnabled="{Binding IsDisabling, Converter={StaticResource InvertBool}}" />
            </Grid>
        </Border>

        <!-- Row 4: Contenido principal -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- Panel izquierdo: Filtros + Tabla -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                    <RadioButton Content="Todos" IsChecked="True" Margin="0,0,8,0" GroupName="Filter" FontSize="11"
                                 Command="{Binding SetFilterCommand}" CommandParameter="Todos" />
                    <RadioButton Content="No Microsoft" Margin="0,0,8,0" GroupName="Filter" FontSize="11"
                                 Command="{Binding SetFilterCommand}" CommandParameter="No Microsoft" />
                    <RadioButton Content="Revisar" Margin="0,0,8,0" GroupName="Filter" FontSize="11"
                                 Command="{Binding SetFilterCommand}" CommandParameter="Recomendados para revisar" />
                    <RadioButton Content="Desactivar" Margin="0,0,8,0" GroupName="Filter" FontSize="11"
                                 Command="{Binding SetFilterCommand}" CommandParameter="Posible desactivar" />
                    <RadioButton Content="Alertas" Margin="0,0,8,0" GroupName="Filter" FontSize="11"
                                 Command="{Binding SetFilterCommand}" CommandParameter="Alertas" />

                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="180"
                             Padding="8,6" FontSize="11" Margin="10,0,0,0" BorderBrush="#CCC" BorderThickness="1"
                             VerticalContentAlignment="Center" />
                </WrapPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding SelectableEntries}" AutoGenerateColumns="False"
                          IsReadOnly="True" SelectionMode="Single" GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column" AlternatingRowBackground="#FAFAFA"
                          BorderBrush="#E0E0E0" BorderThickness="1" RowHeaderWidth="0"
                          CanUserAddRows="False" CanUserSortColumns="True" FontSize="11">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ColumnHeaderStyle}" />
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Sel." Width="45">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:SelectableStartupEntry}">
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              IsEnabled="{Binding IsSelectable}"
                                              Command="{Binding DataContext.ToggleSelectionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              CommandParameter="{Binding}"
                                              HorizontalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Entry.Name}" Width="150" />
                        <DataGridTextColumn Header="Editor" Binding="{Binding Entry.Publisher}" Width="90" />
                        <DataGridTextColumn Header="Origen" Binding="{Binding Entry.SourceType}" Width="100" />
                        <DataGridTextColumn Header="Riesgo" Binding="{Binding Entry.Risk}" Width="70" />
                        <DataGridTextColumn Header="Recomend." Binding="{Binding Entry.Recommendation}" Width="100" />
                        <DataGridTextColumn Header="Comando" Binding="{Binding Entry.Command}" Width="220" />
                        <DataGridTextColumn Header="Razón bloqueo" Binding="{Binding SelectionReason}" Width="140" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Panel derecho: Resumen + Detalle + Backups -->
            <Border Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="15" Background="#FAFAFA">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Resumen -->
                        <TextBlock Text="RESUMEN" FontSize="12" FontWeight="Bold" Foreground="#0078D4" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Text="Total:" FontSize="11" Foreground="#555" /><TextBlock Text="{Binding SummaryTotal}" FontSize="11" FontWeight="SemiBold" Grid.Column="1" /></Grid>
                        <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Text="Microsoft:" FontSize="11" Foreground="#555" /><TextBlock Text="{Binding SummaryMicrosoft}" FontSize="11" FontWeight="SemiBold" Grid.Column="1" /></Grid>
                        <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Text="Terceros:" FontSize="11" Foreground="#555" /><TextBlock Text="{Binding SummaryThirdParty}" FontSize="11" FontWeight="SemiBold" Grid.Column="1" /></Grid>
                        <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Text="Posibles desactivar:" FontSize="11" Foreground="#555" /><TextBlock Text="{Binding SummaryPossibleDisable}" FontSize="11" FontWeight="SemiBold" Foreground="#E65100" Grid.Column="1" /></Grid>
                        <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Text="Alertas:" FontSize="11" Foreground="#555" /><TextBlock Text="{Binding SummaryAlerts}" FontSize="11" FontWeight="SemiBold" Foreground="#C62828" Grid.Column="1" /></Grid>

                        <Separator Background="#E0E0E0" Margin="0,0,0,12" />

                        <!-- Detalle -->
                        <TextBlock Text="DETALLE" FontSize="12" FontWeight="Bold" Foreground="#0078D4" Margin="0,0,0,8" />
                        <TextBlock Text="Seleccioná una entrada" FontSize="11" Foreground="#999"
                                   Visibility="{Binding HasSelectedEntry, Converter={StaticResource InvertBool}}" />

                        <StackPanel Visibility="{Binding HasSelectedEntry, Converter={StaticResource BoolToVis}}">
                            <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="60" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <TextBlock Text="Nombre:" FontSize="10" FontWeight="SemiBold" Foreground="#555" />
                                <TextBlock Text="{Binding SelectedEntry.Name}" FontSize="10" Grid.Column="1" TextWrapping="Wrap" /></Grid>
                            <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="60" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <TextBlock Text="Editor:" FontSize="10" FontWeight="SemiBold" Foreground="#555" />
                                <TextBlock Text="{Binding SelectedEntry.Publisher}" FontSize="10" Grid.Column="1" TextWrapping="Wrap" /></Grid>
                            <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="60" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <TextBlock Text="Riesgo:" FontSize="10" FontWeight="SemiBold" Foreground="#555" />
                                <TextBlock Text="{Binding SelectedEntry.Risk}" FontSize="10" FontWeight="SemiBold" Grid.Column="1" /></Grid>
                            <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="60" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <TextBlock Text="Recomend.:" FontSize="10" FontWeight="SemiBold" Foreground="#555" />
                                <TextBlock Text="{Binding SelectedEntry.Recommendation}" FontSize="10" FontWeight="SemiBold" Grid.Column="1" /></Grid>
                            <TextBlock Text="Comando:" FontSize="10" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,3" />
                            <TextBlock Text="{Binding SelectedEntry.Command}" FontSize="9" Foreground="#333" TextWrapping="Wrap" Margin="0,0,0,6" />
                            <TextBlock Text="{Binding SelectedEntry.Notes}" FontSize="9" Foreground="#E65100" TextWrapping="Wrap"
                                       Visibility="{Binding SelectedEntry.Notes, Converter={StaticResource StringToVis}}" />
                        </StackPanel>

                        <!-- Backups -->
                        <Separator Background="#E0E0E0" Margin="0,12,0,12"
                                   Visibility="{Binding ShowBackups, Converter={StaticResource BoolToVis}}" />

                        <StackPanel Visibility="{Binding ShowBackups, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="BACKUPS" FontSize="12" FontWeight="Bold" Foreground="#0078D4" Margin="0,0,0,8" />

                            <TextBlock Text="No hay backups" FontSize="11" Foreground="#999"
                                       Visibility="{Binding Backups.Count, Converter={StaticResource ZeroToVis}}" />

                            <ItemsControl ItemsSource="{Binding Backups}" MaxHeight="250">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type startup:StartupBackupRecord}">
                                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                                                Padding="8,6" Margin="0,0,0,6" Background="White"
                                                Cursor="Hand">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.LoadBackupsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                            </Border.InputBindings>
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding EntryName}" FontSize="11" FontWeight="SemiBold" />
                                                    <Border Grid.Column="1" CornerRadius="3" Padding="4,1"
                                                            Background="{Binding CanRestore, Converter={StaticResource RestoreColorConverter}}">
                                                        <TextBlock Text="{Binding CanRestore, Converter={StaticResource RestoreTextConverter}}"
                                                                   FontSize="9" Foreground="White" />
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{Binding SourceType}" FontSize="10" Foreground="#666" />
                                                <TextBlock Text="{Binding CreatedAt, StringFormat='Desactivado: {0:dd/MM/yyyy HH:mm}'}"
                                                           FontSize="9" Foreground="#999" />
                                                <TextBlock Text="{Binding DisabledBy}" FontSize="9" Foreground="#999"
                                                           Visibility="{Binding DisabledBy, Converter={StaticResource StringToVis}}" />
                                                <Button Content="Restaurar" FontSize="10" Padding="8,3" Margin="0,4,0,0"
                                                        Background="#E8F5E9" Foreground="#2E7D32" BorderBrush="#A5D6A7"
                                                        BorderThickness="1" HorizontalAlignment="Left"
                                                        Command="{Binding DataContext.RestoreBackupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding CanRestore}"
                                                        Visibility="{Binding CanRestore, Converter={StaticResource BoolToVis}}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
