<UserControl x:Class="Cattech.Optimizer.Pro.UI.Views.StartupAnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Cattech.Optimizer.Pro.UI.Converters"
             xmlns:startup="clr-namespace:Cattech.Optimizer.Pro.Core.Models.Startup;assembly=Cattech.Optimizer.Pro.Core">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InvertBoolConverter x:Key="InvertBool" />
        <converters:StringToVisibilityConverter x:Key="StringToVisConverter" />

        <!-- Color por riesgo -->
        <SolidColorBrush x:Key="RiskLowBrush" Color="#E8F5E9" />
        <SolidColorBrush x:Key="RiskMediumBrush" Color="#FFF8E1" />
        <SolidColorBrush x:Key="RiskHighBrush" Color="#FDECEA" />
        <SolidColorBrush x:Key="RiskUnknownBrush" Color="#F5F5F5" />

        <!-- Template para encabezado de columna -->
        <Style x:Key="ColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F0F0F0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Título -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Programas de Inicio" FontSize="26" FontWeight="Bold" Foreground="#1B1B1B" />
            <TextBlock Text="Análisis de solo lectura. No se modifica nada en el sistema." FontSize="13" Foreground="#666" Margin="0,5,0,0" />
        </StackPanel>

        <!-- Row 1: Mensajes de estado -->
        <StackPanel Grid.Row="1">
            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,10"
                    Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVis}}"
                    Background="#E6F4EA" BorderBrush="#34A853" BorderThickness="1">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#1E7E34" FontWeight="SemiBold" />
            </Border>
            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,10"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                    Background="#FDECEA" BorderBrush="#D93025" BorderThickness="1">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#C62828" FontWeight="SemiBold" />
            </Border>
        </StackPanel>

        <!-- Row 2: Botones y filtros -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="15" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="🔍 Analizar programas de inicio"
                    Command="{Binding AnalyzeCommand}"
                    Padding="18,10" FontSize="13" FontWeight="SemiBold"
                    Background="#0078D4" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    IsEnabled="{Binding IsRunning, Converter={StaticResource InvertBool}}" />

            <Button Grid.Column="2"
                    Content="💾 Guardar análisis"
                    Command="{Binding SaveAnalysisCommand}"
                    Padding="16,10" FontSize="13"
                    Background="#F3F3F3" Foreground="#333"
                    BorderBrush="#CCC" BorderThickness="1"
                    Cursor="Hand"
                    IsEnabled="{Binding HasResults}" />

            <TextBox Grid.Column="3"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="10,8" FontSize="13" Margin="15,0,15,0"
                     BorderBrush="#CCC" BorderThickness="1"
                     VerticalContentAlignment="Center">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Tag" Value="Buscar por nombre, ruta o editor..." />
                    </Style>
                </TextBox.Style>
            </TextBox>

            <TextBlock Grid.Column="4" Text="{Binding StatusText}" FontSize="12"
                       Foreground="#666" VerticalAlignment="Center" />
        </Grid>

        <!-- Row 3: Contenido principal -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- Panel izquierdo: Filtros + Tabla -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Filtros -->
                <WrapPanel Grid.Row="0" Margin="0,0,0,10">
                    <RadioButton Content="Todos" IsChecked="True" Margin="0,0,10,0"
                                 GroupName="Filter" FontSize="12"
                                 Command="{Binding SetFilterCommand}" CommandParameter="Todos" />
                    <RadioButton Content="No Microsoft" Margin="0,0,10,0"
                                 GroupName="Filter" FontSize="12"
                                 Command="{Binding SetFilterCommand}" CommandParameter="No Microsoft" />
                    <RadioButton Content="Revisar" Margin="0,0,10,0"
                                 GroupName="Filter" FontSize="12"
                                 Command="{Binding SetFilterCommand}" CommandParameter="Recomendados para revisar" />
                    <RadioButton Content="Posible desactivar" Margin="0,0,10,0"
                                 GroupName="Filter" FontSize="12"
                                 Command="{Binding SetFilterCommand}" CommandParameter="Posible desactivar" />
                    <RadioButton Content="Alertas" Margin="0,0,10,0"
                                 GroupName="Filter" FontSize="12"
                                 Command="{Binding SetFilterCommand}" CommandParameter="Alertas" />
                </WrapPanel>

                <!-- Tabla -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding FilteredEntries}"
                          SelectedItem="{Binding SelectedEntry}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="#FAFAFA"
                          BorderBrush="#E0E0E0" BorderThickness="1"
                          RowHeaderWidth="0"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserSortColumns="True"
                          FontSize="12">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ColumnHeaderStyle}" />
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="180" />
                        <DataGridTextColumn Header="Editor" Binding="{Binding Publisher}" Width="100" />
                        <DataGridTextColumn Header="Origen" Binding="{Binding SourceType}" Width="110" />
                        <DataGridTextColumn Header="Estado" Binding="{Binding Status}" Width="90" />
                        <DataGridTextColumn Header="Riesgo" Binding="{Binding Risk}" Width="80" />
                        <DataGridTextColumn Header="Recomendación" Binding="{Binding Recommendation}" Width="130" />
                        <DataGridTextColumn Header="Comando" Binding="{Binding Command}" Width="250" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Panel derecho: Resumen + Detalle -->
            <Border Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="1"
                    CornerRadius="6" Padding="15" Background="#FAFAFA">
                <StackPanel>

                    <TextBlock Text="RESUMEN" FontSize="12" FontWeight="Bold"
                               Foreground="#0078D4" Margin="0,0,0,10" />

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Total encontrados:" FontSize="12" Foreground="#555" />
                        <TextBlock Text="{Binding SummaryTotal}" FontSize="12" FontWeight="SemiBold" Grid.Column="1" />
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Microsoft / sistema:" FontSize="12" Foreground="#555" />
                        <TextBlock Text="{Binding SummaryMicrosoft}" FontSize="12" FontWeight="SemiBold" Grid.Column="1" />
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Terceros:" FontSize="12" Foreground="#555" />
                        <TextBlock Text="{Binding SummaryThirdParty}" FontSize="12" FontWeight="SemiBold" Grid.Column="1" />
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Posibles desactivar:" FontSize="12" Foreground="#555" />
                        <TextBlock Text="{Binding SummaryPossibleDisable}" FontSize="12" FontWeight="SemiBold" Foreground="#E65100" Grid.Column="1" />
                    </Grid>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Alertas:" FontSize="12" Foreground="#555" />
                        <TextBlock Text="{Binding SummaryAlerts}" FontSize="12" FontWeight="SemiBold" Foreground="#C62828" Grid.Column="1" />
                    </Grid>

                    <Separator Background="#E0E0E0" Margin="0,0,0,15" />

                    <!-- Detalle de entrada seleccionada -->
                    <TextBlock Text="DETALLE" FontSize="12" FontWeight="Bold"
                               Foreground="#0078D4" Margin="0,0,0,10" />

                    <TextBlock Text="Seleccioná una entrada para ver detalles"
                               FontSize="12" Foreground="#999"
                               Visibility="{Binding HasSelectedEntry, Converter={StaticResource InvertBool}}" />

                    <StackPanel Visibility="{Binding HasSelectedEntry, Converter={StaticResource BoolToVis}}">

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Nombre:" FontSize="11" FontWeight="SemiBold" Foreground="#555" />
                            <TextBlock Text="{Binding SelectedEntry.Name}" FontSize="11" Grid.Column="1"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Editor:" FontSize="11" FontWeight="SemiBold" Foreground="#555" />
                            <TextBlock Text="{Binding SelectedEntry.Publisher}" FontSize="11" Grid.Column="1"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Origen:" FontSize="11" FontWeight="SemiBold" Foreground="#555" />
                            <TextBlock Text="{Binding SelectedEntry.SourceType}" FontSize="11" Grid.Column="1" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Estado:" FontSize="11" FontWeight="SemiBold" Foreground="#555" />
                            <TextBlock Text="{Binding SelectedEntry.Status}" FontSize="11" Grid.Column="1" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Riesgo:" FontSize="11" FontWeight="SemiBold" Foreground="#555" />
                            <TextBlock Text="{Binding SelectedEntry.Risk}" FontSize="11" FontWeight="SemiBold" Grid.Column="1" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Recomend.:" FontSize="11" FontWeight="SemiBold" Foreground="#555" />
                            <TextBlock Text="{Binding SelectedEntry.Recommendation}" FontSize="11" FontWeight="SemiBold" Grid.Column="1" />
                        </Grid>

                        <TextBlock Text="Comando:" FontSize="11" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding SelectedEntry.Command}" FontSize="10" Foreground="#333"
                                   TextWrapping="Wrap" Margin="0,0,0,8" />

                        <TextBlock Text="Ubicación:" FontSize="11" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding SelectedEntry.Location}" FontSize="10" Foreground="#333"
                                   TextWrapping="Wrap" Margin="0,0,0,8" />

                        <TextBlock Text="Notas:" FontSize="11" FontWeight="SemiBold" Foreground="#555"
                                   Visibility="{Binding SelectedEntry.Notes, Converter={StaticResource StringToVisConverter}}" />
                        <TextBlock Text="{Binding SelectedEntry.Notes}" FontSize="10" Foreground="#E65100"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>

        <!-- Row 4: Leyenda -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBlock Text="Leyenda: " FontSize="11" Foreground="#666" FontWeight="SemiBold" />
            <Border Background="#E8F5E9" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                <TextBlock Text="Bajo" FontSize="10" />
            </Border>
            <Border Background="#FFF8E1" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                <TextBlock Text="Medio" FontSize="10" />
            </Border>
            <Border Background="#FDECEA" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                <TextBlock Text="Alto" FontSize="10" />
            </Border>
        </StackPanel>

    </Grid>
</UserControl>
