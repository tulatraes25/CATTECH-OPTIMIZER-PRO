<UserControl x:Class="Cattech.Optimizer.Pro.UI.Views.RestorePointView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Cattech.Optimizer.Pro.UI.Converters"
             xmlns:rp="clr-namespace:Cattech.Optimizer.Pro.Core.Interfaces;assembly=Cattech.Optimizer.Pro.Core">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InvertBoolConverter x:Key="InvertBool" />
        <converters:StringToVisibilityConverter x:Key="StringToVis" />
        <converters:ZeroToVisibilityConverter x:Key="ZeroToVis" />
        <converters:BoolToVisYesNoConverter x:Key="BoolToVisYesNo" />
        <converters:AdminColorConverter x:Key="AdminColorConverter" />
        <converters:StatusColorConverter x:Key="StatusColorConverter" />
        <converters:CanCreateColorConverter x:Key="CanCreateColorConverter" />
        <converters:CanCreateTextConverter x:Key="CanCreateTextConverter" />
        <converters:ResultColorConverter x:Key="ResultColorConverter" />
        <converters:SuccessTextConverter x:Key="SuccessTextConverter" />
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Row 0: Título -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Punto de Restauración" FontSize="26" FontWeight="Bold" Foreground="#1B1B1B" />
            <TextBlock Text="Crear un punto de restauración antes de aplicar cambios importantes en el sistema."
                       FontSize="13" Foreground="#666" Margin="0,5,0,0" />
        </StackPanel>

        <!-- Row 1: Mensajes -->
        <StackPanel Grid.Row="1">
            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,10"
                    Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVis}}"
                    Background="#E6F4EA" BorderBrush="#34A853" BorderThickness="1">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#1E7E34" FontWeight="SemiBold" />
            </Border>
            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,10"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                    Background="#FDECEA" BorderBrush="#D93025" BorderThickness="1">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#C62828" FontWeight="SemiBold" />
            </Border>
        </StackPanel>

        <!-- Row 2: Botones principales -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="🔍 Verificar estado"
                    Command="{Binding CheckStatusCommand}" Padding="16,8" FontSize="12" FontWeight="SemiBold"
                    Background="#0078D4" Foreground="White" BorderThickness="0"
                    IsEnabled="{Binding IsRunning, Converter={StaticResource InvertBool}}" />

            <Button Grid.Column="2" Content="🛡️ Crear punto de restauración"
                    Command="{Binding CreateRestorePointCommand}" Padding="16,8" FontSize="12" FontWeight="SemiBold"
                    Background="#2E7D32" Foreground="White" BorderThickness="0"
                    IsEnabled="{Binding CanCreatePoint}" />

            <Button Grid.Column="4" Content="📋 Historial"
                    Command="{Binding LoadHistoryCommand}" Padding="12,8" FontSize="11"
                    Background="#F3F3F3" Foreground="#333" BorderBrush="#CCC" BorderThickness="1" />

            <TextBlock Grid.Column="6" Text="{Binding StatusText}" FontSize="12" Foreground="#666" VerticalAlignment="Center" />
        </Grid>

        <!-- Row 3: Barra de progreso -->
        <ProgressBar Grid.Row="3" Value="0" Maximum="100" Height="6" Margin="0,0,0,10"
                     Background="#E0E0E0" Foreground="#0078D4"
                     Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}" />

        <!-- Row 4: Contenido principal -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- Panel izquierdo: Estado del sistema -->
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <!-- Estado del sistema -->
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6"
                        Padding="15" Background="White" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="ESTADO DEL SISTEMA" FontSize="12" FontWeight="Bold"
                                   Foreground="#0078D4" Margin="0,0,0,10" />

                        <TextBlock Text="Verificá el estado antes de crear un punto." FontSize="12" Foreground="#999"
                                   Visibility="{Binding HasStatus, Converter={StaticResource InvertBool}}" />

                        <StackPanel Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}">
                            <!-- Administrador -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Permisos: " FontSize="13" Foreground="#555" />
                                    <TextBlock Text="{Binding AdminStatusText}" FontSize="13" FontWeight="SemiBold" />
                                </StackPanel>
                                <Border Grid.Column="1" HorizontalAlignment="Right" CornerRadius="3" Padding="6,2"
                                        Background="{Binding IsAdministrator, Converter={StaticResource AdminColorConverter}}">
                                    <TextBlock Text="{Binding IsAdministrator, Converter={StaticResource BoolToVisYesNo}}"
                                               FontSize="11" Foreground="White" />
                                </Border>
                            </Grid>

                            <!-- Servicio -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Servicio Restaurar: " FontSize="13" Foreground="#555" />
                                    <TextBlock Text="{Binding RestoreServiceText}" FontSize="13" FontWeight="SemiBold" />
                                </StackPanel>
                                <Border Grid.Column="1" HorizontalAlignment="Right" CornerRadius="3" Padding="6,2"
                                        Background="{Binding IsSystemRestoreAvailable, Converter={StaticResource StatusColorConverter}}">
                                    <TextBlock Text="{Binding IsSystemRestoreAvailable, Converter={StaticResource BoolToVisYesNo}}"
                                               FontSize="11" Foreground="White" />
                                </Border>
                            </Grid>

                            <!-- Protección -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Protección del sistema: " FontSize="13" Foreground="#555" />
                                    <TextBlock Text="{Binding ProtectionText}" FontSize="13" FontWeight="SemiBold" />
                                </StackPanel>
                                <Border Grid.Column="1" HorizontalAlignment="Right" CornerRadius="3" Padding="6,2"
                                        Background="{Binding IsProtectionEnabled, Converter={StaticResource StatusColorConverter}}">
                                    <TextBlock Text="{Binding IsProtectionEnabled, Converter={StaticResource BoolToVisYesNo}}"
                                               FontSize="11" Foreground="White" />
                                </Border>
                            </Grid>

                            <!-- Disponibilidad -->
                            <Border Background="{Binding CanCreatePoint, Converter={StaticResource CanCreateColorConverter}}"
                                    CornerRadius="6" Padding="12,10" Margin="0,5,0,0">
                                <StackPanel>
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="White">
                                        <Run Text="{Binding CanCreatePoint, Converter={StaticResource CanCreateTextConverter}}" />
                                    </TextBlock>
                                    <TextBlock Text="Los puntos de restauración permiten revertir cambios importantes en el sistema."
                                               FontSize="11" Foreground="White" Opacity="0.9"
                                               Visibility="{Binding CanCreatePoint, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Nombre del punto -->
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6"
                        Padding="15" Background="White" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="NOMBRE DEL PUNTO" FontSize="12" FontWeight="Bold"
                                   Foreground="#0078D4" Margin="0,0,0,8" />
                        <TextBox Text="{Binding RestorePointName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" FontSize="13" BorderBrush="#CCC" BorderThickness="1"
                                 IsEnabled="{Binding CanCreatePoint}" />
                        <TextBlock Text="Nombre descriptivo para identificar el punto de restauración."
                                   FontSize="11" Foreground="#999" Margin="0,5,0,0" />
                    </StackPanel>
                </Border>

                <!-- Advertencias -->
                <Border BorderBrush="#FFB74D" BorderThickness="1" CornerRadius="6"
                        Padding="12,10" Background="#FFF8E1">
                    <StackPanel>
                        <TextBlock Text="⚠️ Información importante" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#E65100" Margin="0,0,0,6" />
                        <TextBlock Text="• Windows puede limitar la creación de puntos si ya se creó uno recientemente" FontSize="11" Foreground="#555" />
                        <TextBlock Text="• Se requieren permisos de administrador" FontSize="11" Foreground="#555" />
                        <TextBlock Text="• La protección del sistema debe estar habilitada" FontSize="11" Foreground="#555" />
                        <TextBlock Text="• No se eliminan puntos de restauración existentes" FontSize="11" Foreground="#555" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Panel derecho: Resultado + Historial -->
            <Border Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6"
                    Padding="15" Background="#FAFAFA">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Resultado -->
                        <TextBlock Text="RESULTADO" FontSize="12" FontWeight="Bold"
                                   Foreground="#0078D4" Margin="0,0,0,10"
                                   Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}" />

                        <Border Background="{Binding ResultSuccess, Converter={StaticResource ResultColorConverter}}"
                                CornerRadius="6" Padding="12,10" Margin="0,0,0,10"
                                Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="{Binding ResultSummary}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="White" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ResultDetails}" FontSize="11" Foreground="White"
                                           TextWrapping="Wrap" Opacity="0.9" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>

                        <Separator Background="#E0E0E0" Margin="0,0,0,12"
                                   Visibility="{Binding ShowHistory, Converter={StaticResource BoolToVis}}" />

                        <!-- Historial -->
                        <StackPanel Visibility="{Binding ShowHistory, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="HISTORIAL" FontSize="12" FontWeight="Bold"
                                       Foreground="#0078D4" Margin="0,0,0,8" />

                            <TextBlock Text="No hay intentos registrados" FontSize="11" Foreground="#999"
                                       Visibility="{Binding History.Count, Converter={StaticResource ZeroToVis}}" />

                            <ItemsControl ItemsSource="{Binding History}" MaxHeight="250">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type rp:RestorePointResultSummary}">
                                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                                                Padding="8,6" Margin="0,0,0,6" Background="White">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding RestorePointName}" FontSize="11"
                                                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <Border Grid.Column="1" CornerRadius="3" Padding="4,1"
                                                            Background="{Binding Success, Converter={StaticResource ResultColorConverter}}">
                                                        <TextBlock Text="{Binding Success, Converter={StaticResource SuccessTextConverter}}"
                                                                   FontSize="9" Foreground="White" />
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{Binding RequestedAt, StringFormat='Fecha: {0:dd/MM/yyyy HH:mm}'}"
                                                           FontSize="9" Foreground="#999" />
                                                <TextBlock Text="{Binding ErrorMessage}" FontSize="9" Foreground="#C62828"
                                                           TextWrapping="Wrap"
                                                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVis}}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
